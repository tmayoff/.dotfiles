[init]
	defaultBrance = main

[author]
	email = tyler@tylermayoff.com
	name = Tyler Mayoff
[user]
	email = tyler@tylermayoff.com
	name = Tyler Mayoff
[core]
	excludesFile = ~/.config/.gitignore
[merge]
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
[diff]
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[pull]
	rebase = false
